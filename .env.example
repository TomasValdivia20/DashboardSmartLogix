# Variables de Entorno - Dashboard SmartLogix
# Copia este archivo a .env.local para desarrollo local
# En Vercel, configura estas variables en Project Settings > Environment Variables

# API Configuration
VITE_API_URL=https://api.tudominio.com
VITE_API_TIMEOUT=30000

# Application
VITE_APP_NAME=SmartLogix Dashboard
VITE_APP_ENVIRONMENT=production

# Feature Flags (opcional)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_MODE=false
